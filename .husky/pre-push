CHANGED=$(git diff --name-only --diff-filter=ACMR @{u}.. 2>/dev/null | { grep -E '\.(md|json|yml|yaml|js|jsx|ts|tsx|css|scss)$' || true; } | { grep -vE '^(client|api|curriculum|tools|packages)/.*(\.test\.|/dist/|/build/|/node_modules/)' || true; })

if [ -z "$CHANGED" ]; then
  exit 0
fi

echo "Pre-push: prettier check sur fichiers modifies..."
# -n 50 evite le bug Windows "ligne de commande trop longue" quand un commit
# touche beaucoup de fichiers (ex: workshop de 67+ fichiers).
echo "$CHANGED" | xargs -n 50 pnpm prettier --check
if [ $? -ne 0 ]; then
  echo ""
  echo "Prettier check echoue. Lance 'pnpm prettier --write <fichier>' pour corriger, puis commit/push."
  exit 1
fi
